# Sukari environment variables

# Analytics (optional - web only for now)
# Create a PostHog project and paste the project API key here
EXPO_PUBLIC_POSTHOG_KEY=
# Optional: self-hosted instance or PostHog Cloud (default: https://app.posthog.com)
EXPO_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Sukari API for optional coach and published digest endpoints.
# Leave blank for the local-first demo.
EXPO_PUBLIC_SUKARI_API_URL=

# LLM providers (worker secrets — not required in Expo client):
# Primary: Runware textInference  https://runware.ai/docs/platform/introduction
#   cd server/leaderboard-worker && npx wrangler secret put RUNWARE_API_KEY
# Fallback: OpenAI chat completions
#   cd server/leaderboard-worker && npx wrangler secret put OPENAI_API_KEY
# Optional local copies for scripts/testing:
# RUNWARE_API_KEY=
# Optional model override for vetted mission illustrations. No raw health data is sent.
# RUNWARE_IMAGE_MODEL=runware:101@1
# OPENAI_API_KEY=

# Public app URL for generated share links. Keep this hostname through submission.
EXPO_PUBLIC_APP_URL=https://sukari.famile.xyz

# Error monitoring (optional — falls back to console)
EXPO_PUBLIC_SENTRY_DSN=

# Dexcom CGM Integration (optional — educational read-only)
# Register at https://developer.dexcom.com
EXPO_PUBLIC_DEXCOM_CLIENT_ID=
EXPO_PUBLIC_DEXCOM_REDIRECT_URI=
# Set to 'false' for production Dexcom API (default: sandbox)
EXPO_PUBLIC_DEXCOM_SANDBOX=true
