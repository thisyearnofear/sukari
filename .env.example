# Glucose Wars Environment Variables

# WalletConnect Project ID (optional — legacy native Scroll/VRF paths only)
# Get from: https://cloud.walletconnect.com
# EXPO_PUBLIC_WALLET_CONNECT_PROJECT_ID=your_walletconnect_project_id_here

# RPC Configuration (optional - defaults to Scroll Sepolia)
# EXPO_PUBLIC_RPC_URL=https://sepolia-rpc.scroll.io

# Analytics (optional - web only for now)
# Create a PostHog project and paste the project API key here
EXPO_PUBLIC_POSTHOG_KEY=
# Optional: self-hosted instance or PostHog Cloud (default: https://app.posthog.com)
EXPO_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Global leaderboard + coach + digest worker (optional)
# Deployed: https://glucosewars-leaderboard.papaandthejimjams.workers.dev
EXPO_PUBLIC_LEADERBOARD_API_URL=https://glucosewars-leaderboard.papaandthejimjams.workers.dev
EXPO_PUBLIC_LEADERBOARD_WORKER_URL=https://glucosewars-leaderboard.papaandthejimjams.workers.dev
# Alias also accepted by coach/digest clients:
# EXPO_PUBLIC_WORKER_URL=

# LLM providers (worker secrets — not required in Expo client):
# Primary: Runware textInference  https://runware.ai/docs/platform/introduction
#   cd server/leaderboard-worker && npx wrangler secret put RUNWARE_API_KEY
# Fallback: OpenAI chat completions
#   cd server/leaderboard-worker && npx wrangler secret put OPENAI_API_KEY
# Optional local copies for scripts/testing:
# RUNWARE_API_KEY=
# OPENAI_API_KEY=

# App URL for share links (Netlify production)
EXPO_PUBLIC_APP_URL=https://glucosewars.netlify.app

# Beam SDK (optional — runs in offline mode without these)
EXPO_PUBLIC_BEAM_PUBLISHABLE_KEY=
# Set to 'true' for mainnet, omit or 'false' for testnet
EXPO_PUBLIC_BEAM_MAINNET=false
# Game contract address on Beam network (for result reporting)
EXPO_PUBLIC_BEAM_GAME_CONTRACT=

# NFT metadata base URI (IPFS gateway or CDN hosting achievement images)
EXPO_PUBLIC_NFT_METADATA_BASE_URI=https://glucosewars.app/metadata

# Error monitoring (optional — falls back to console)
EXPO_PUBLIC_SENTRY_DSN=

# Dexcom CGM Integration (optional — educational read-only)
# Register at https://developer.dexcom.com
EXPO_PUBLIC_DEXCOM_CLIENT_ID=
EXPO_PUBLIC_DEXCOM_REDIRECT_URI=
# Set to 'false' for production Dexcom API (default: sandbox)
EXPO_PUBLIC_DEXCOM_SANDBOX=true
